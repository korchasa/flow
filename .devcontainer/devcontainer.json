{
  "name": "flowai",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/deno:latest": {},
    "ghcr.io/jsburckhardt/devcontainer-features/opencode:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "denoland.vscode-deno",
        "anthropic.claude-code",
        "eamodio.gitlens",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "deno.enable": true,
        "deno.lint": true,
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.formatOnSave": true
      }
    }
  },

  // No remoteEnv / no secrets — all authentication (Claude, GitHub, OpenCode, ...)
  // is the user's responsibility and is performed manually inside the container.
  // Passing ANTHROPIC_API_KEY through ${localEnv:...} is specifically dangerous:
  // when the variable is unset on the host, it resolves to an empty string and
  // Claude Code interprets that as an explicit API-key auth attempt, breaking
  // the OAuth flow the user runs via `claude login`.

  "mounts": [
    "source=${localWorkspaceFolderBasename}-claude-config,target=/home/vscode/.claude,type=volume",
    "source=${localWorkspaceFolderBasename}-opencode-config,target=/home/vscode/.config/opencode,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude-host,type=bind,readonly",
    "source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode-host,type=bind,readonly",
    "source=${localWorkspaceFolderBasename}-bashhistory,target=/commandhistory,type=volume"
  ],

  // Object form runs entries in parallel. Volume chown lives inside
  // setup-container.sh as a self-healing guard; CLI installers only touch
  // ~/.local/bin, so there is no race between `setup` and the *-cli entries.
  "postCreateCommand": {
    "deps": "deno install",
    "setup": ".devcontainer/setup-container.sh",
    "claude-cli": "curl -fsSL https://claude.ai/install.sh | bash"
  },

  "postStartCommand": {
    "git-safe": "git config --global --add safe.directory ${containerWorkspaceFolder}",
    "claude-sync": "rm -rf ~/.claude/skills ~/.claude/commands && cp -rL ~/.claude-host/skills ~/.claude/skills 2>/dev/null || true && cp -rL ~/.claude-host/commands ~/.claude/commands 2>/dev/null || true",
    "opencode-sync": "rm -rf ~/.config/opencode/skills && cp -rL ~/.config/opencode-host/skills ~/.config/opencode/skills 2>/dev/null || true"
  },

  "remoteUser": "vscode"
}
